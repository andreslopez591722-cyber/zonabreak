# Base de datos MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://andreslopez591722_db_user:TU_PASSWORD_AQUI@cluster0.mongodb.net/zonabreak?retryWrites=true&w=majority

# Seguridad JWT — cambia esto por una cadena aleatoria larga en producción
